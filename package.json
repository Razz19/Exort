{
  "name": "exort",
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace @exortai/desktop run dev",
    "build": "npm --workspace @exortai/desktop run build",
    "lint": "turbo run lint",
    "typecheck": "npm --workspace @exortai/desktop run typecheck",
    "format": "turbo run format"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}